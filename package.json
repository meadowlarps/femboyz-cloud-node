{
  "name": "femboyz-cloud-node",
  "version": "2.0.0",
  "description": "rewrite of https://github.com/misikovich/femboyz-cloud-server in Typescript",
  "main": "index.js",
  "scripts": {
    "dev": "docker compose up -d && NODE_ENV=dev LOGLEVEL=debug tsx src/index.ts; docker compose down",
    "dev:watch": "NODE_ENV=dev LOGLEVEL=debug tsx watch src/index.ts",
    "build": "tsc",
    "start": "NODE_ENV=prod node dist/index.js",
    "test": "tsc && NODE_ENV=dev LOGLEVEL=debug vitest run --reporter=verbose"
  },
  "keywords": [],
  "author": "meadowlarps, misikovich",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "filesize": "^11.0.17",
    "mongodb": "^7.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "wasmagic": "^1.0.8",
    "zod": "^4.4.3"
  }
}
