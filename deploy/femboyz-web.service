[Unit]
Description=femboyz.cloud web client
After=network-online.target femboyz-api.service
Wants=network-online.target

[Service]
Type=simple
User=femboyz
Group=femboyz
WorkingDirectory=/srv/femboyz-cloud/client
Environment=HOST=127.0.0.1
Environment=PORT=3001
Environment=ORIGIN=https://femboyz.cloud
Environment=INTERNAL_API_ENDPOINT=http://127.0.0.1:3000
ExecStart=/usr/bin/node build
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
